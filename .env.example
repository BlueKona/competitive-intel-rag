# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit real keys.

# --- LLM + embeddings (OpenAI) ---
# Used by the chat agent (gpt-5-mini) and by the embedding nodes in both workflows.
OPENAI_API_KEY=

# --- Vector store (Pinecone) ---
# API key for the Pinecone account that hosts the review index.
PINECONE_API_KEY=
# Name of the Pinecone index the workflows read/write (this project uses "competitor-reviews").
PINECONE_INDEX=competitor-reviews

# --- Scraping (Firecrawl) ---
# Used by the indexer workflow to scrape public G2 review pages.
FIRECRAWL_API_KEY=

# --- Generation model ---
# The chat model the agent runs on.
OPENAI_CHAT_MODEL=gpt-5-mini
